DATABASE_URL=postgresql://neondb_owner:your_password@your_host/neondb?sslmode=require
GROQ_API_KEY=your_groq_api_key
# If you also keep a repo-root .env, avoid duplicate GROQ_API_KEY there with an old value - backend/.env loads first and wins.
# DANGEROUS: only for local debugging invalid-key errors. Logs the full key to the server console. Unset after use.
# GROQ_DEBUG_PRINT_FULL_KEY=1
# Optional. Defaults to llama-3.3-70b-versatile (Groq production). Set if you need another model ID.
# GROQ_MODEL=llama-3.1-8b-instant
# Optional web-search controls for chat:
# WEB_SEARCH_ENABLED=true
# WEB_SEARCH_MAX_RESULTS=3
# WEB_SEARCH_TIMEOUT_MS=12000
# WEB_SEARCH_DECIDER=heuristic
# WEB_SEARCH_DEBUG=0
# GROQ_CHAT_MAX_TOKENS=700
# CHAT_CONTEXT_MAX_CHARS=3000
SESSION_SECRET=change_this_to_a_long_random_string
PORT=4000
